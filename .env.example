# Werte die ins Flutter-Web-Bundle gebaut werden (sind im Browser sichtbar — by design public)
# Optional: Override für Brew-Proxy URL (z.B. wenn Proxy auf anderem VPS liegt).
# Leer lassen → EnvConfig leitet aus aktuellem Hostname ab (non-local: api.<domain>/api).
PROXY_URL=
# Optional: Override für Supabase Kong Gateway URL (z.B. wenn Supabase auf anderem VPS liegt).
# Leer lassen → EnvConfig leitet aus aktuellem Hostname ab (non-local: supabase.<domain>).
SUPABASE_URL=
SUPABASE_ANON_KEY=<generiert via scripts/generate-supabase-secrets.sh>

# ─── Docker Compose ───
DOCKERHUB_USERNAME=<dein-dockerhub-user>
WEB_RAPT_PORT=8082
